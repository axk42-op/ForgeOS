# Supabase (Forge OS cloud accounts)
# Copy to .env and fill in your project values.
# Get these from: Supabase Dashboard → Project Settings → API

FORGEOS_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
FORGEOS_SUPABASE_KEY=YOUR_SERVICE_ROLE_KEY

# Use the service role key for CLI writes (keep secret — never commit .env).
# Passwords are stored as salted SHA-256 hashes in forge_users.password_hash.
